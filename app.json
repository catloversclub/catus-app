{
  "expo": {
    "name": "Catus",
    "slug": "catus-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/ios-light.png",
    "scheme": "catus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.catloversclub.catus.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDisplayName": "Catus",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "entitlements": {
          "aps-environment": "development"
        }
      },
      "icon": {
        "dark": "./assets/images/logo/ios-dark.png",
        "light": "./assets/images/logo/ios-light.png"
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.catloversclub.catus.app",
      "googleServicesFile": "./google-services.json",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF",
          "image": "./assets/images/logo/col-light.png",
          "dark": {
            "image": "./assets/images/logo/col-dark.png",
            "backgroundColor": "#000"
          },
          "imageWidth": 200
        }
      ],
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "510bc3970b990aa960265ab40e5c434b",
          "kotlinVersion": "2.1.21"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://devrepo.kakao.com/nexus/content/groups/public/"
            ]
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "고양이 사진에 접근하여 친구들과 공유할 수 있습니다."
        }
      ],
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "고양이 사진에 접근하여 업로드할 수 있습니다.",
          "savePhotosPermission": "고양이 사진을 갤러리에 저장할 수 있습니다.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ef7cc24-3a82-4f5e-876f-f61d6c693e5a"
      }
    },
    "owner": "catloversclub"
  }
}
